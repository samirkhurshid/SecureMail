# ─────────────────────────────────────────────────────────────────
#  Email Security Gateway — Environment Configuration
#  Copy this file to .env and fill in your API keys.
# ─────────────────────────────────────────────────────────────────

# ── Required API Keys ─────────────────────────────────────────────
# Get free keys at:
#   VirusTotal : https://www.virustotal.com/gui/join-us
#   AbuseIPDB  : https://www.abuseipdb.com/register

VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# ── App Configuration ─────────────────────────────────────────────
APP_ENV=development           # development | production
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
SCAN_TIMEOUT_SECONDS=30

# ── File Scanning ─────────────────────────────────────────────────
MAX_ATTACHMENT_SIZE_MB=32

# ── Rate Limits (free tier defaults) ─────────────────────────────
VT_REQUESTS_PER_MINUTE=4          # VirusTotal free: 4/min, 500/day
ABUSEIPDB_REQUESTS_PER_DAY=1000   # AbuseIPDB free: 1000/day

# ── Risk Thresholds ───────────────────────────────────────────────
VT_MALICIOUS_THRESHOLD=3          # Min VT detections to flag as threat
ABUSEIPDB_CONFIDENCE_THRESHOLD=25 # Min abuse confidence % to flag IP
RISK_SCORE_HIGH=70                # Score >= this → HIGH risk
RISK_SCORE_MEDIUM=40              # Score >= this → MEDIUM risk

# ── Forensics Storage ─────────────────────────────────────────────
FORENSICS_LOG_DIR=./forensics_logs
FORENSICS_MAX_LOGS=10000
